# Copy to `.env` to override defaults. Docker Compose loads it automatically.

# Host port the viewer is published on. Default 6001.
#PORT=6001

# Host user/group the container runs as — so files written to ./runs and
# ./agents on the host are owned by you, not root.
#   Linux users with UID 1000 can skip this (defaults work).
#   macOS users: `echo "UID=$(id -u)" > .env && echo "GID=$(id -g)" >> .env`
#UID=1000
#GID=1000
